.entry main
.import std

_ifless:
    print "smaller than 10"
    ret

_ifgreater:
    print "greater than 10"
    ret

_ifequal:
    print "equal to 10"
    ret

%my_value:
    .object

const COMPARISON_VALUE 10

main:
    print "Hello, world!"

    mov my_value, 10

    cmp my_value, COMPARISON_VALUE
    call _ifless, ifless
    call _ifgreater, ifgreater
    call _ifequal, ifequal

    call debug_std_function

    mov regR, 55

    ret